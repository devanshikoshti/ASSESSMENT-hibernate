<!DOCTYPE html>
<html>
<head>
    <title>Add Post</title>
</head>
<body>

<h2>Add Blog Post</h2>

<form action="addPost" method="post">

    Title:
    <input type="text" name="title"><br><br>

    Content:
    <textarea name="content"></textarea><br><br>

    Tags:
    <input type="text" name="tags"><br><br>

    <input type="submit" value="Add Post">

</form>

</body>
</html>